# Copie para .env (ou configure direto no painel da hospedagem)

# Chave da API da Anthropic (obrigatória) — https://platform.claude.com
ANTHROPIC_API_KEY=sk-ant-...

# Número do WhatsApp da clínica para o botão "Agendar" (só dígitos, com DDI)
# Ex.: 5511999999999
WHATSAPP_NUMERO=

# Token para exportar os leads em /api/leads.csv?token=SEU_TOKEN
ADMIN_TOKEN=troque-por-um-token-secreto

# Opcional
# CLAUDE_MODEL=claude-opus-4-8
# MAX_ANALISES_POR_IP_HORA=6
# DB_PATH=/data/leads.db
